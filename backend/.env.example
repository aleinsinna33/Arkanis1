# Copia questo file in .env e compila i valori

# Server
PORT=4000
NODE_ENV=development

# Database PostgreSQL
# Formato: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://arkanis_user:password@localhost:5432/arkanis_db

# JWT Secret (genera una stringa random lunga)
JWT_SECRET=cambia_questa_stringa_con_qualcosa_di_random_lungo_almeno_64_caratteri

# Solana Treasury Wallet (riceve i pagamenti SOL)
SOLANA_TREASURY_WALLET=IL_TUO_INDIRIZZO_WALLET_SOLANA
SOLANA_NETWORK=mainnet-beta

# Frontend URL (per CORS)
FRONTEND_URL=http://localhost:5173
